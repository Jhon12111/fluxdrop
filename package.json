{
  "name": "fluxdrop",
  "productName": "FluxDrop",
  "version": "1.3.0",
  "description": "Universal high-speed LAN file transfer for Windows and macOS",
  "main": "src/main.js",
  "author": "Ashik Mahmud <ashikmahmud284@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jhon12111/fluxdrop.git"
  },
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "test": "node test/selftest.js && node test/cancel-hang.js",
    "icons": "node scripts/genicon.js",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ashikmahmud.fluxdrop",
    "productName": "FluxDrop",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "src/**/*",
      "build/*.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "shortcutName": "FluxDrop"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}.${ext}"
    }
  }
}
